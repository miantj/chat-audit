{
  "name": "chat-audit-export",
  "version": "1.0.0",
  "description": "一手聊天审计导出工具",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "prestart": "node scripts/ensure-deps.cjs",
    "start": "electron .",
    "rebuild:electron": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ pnpm rebuild electron",
    "prepare-runtime": "node scripts/prepare-runtime.cjs",
    "prebuild": "node scripts/prepare-runtime.cjs --win-x64 && node scripts/copy-ws-to-scripts.cjs",
    "prebuild:mac": "node scripts/prepare-runtime.cjs && node scripts/copy-ws-to-scripts.cjs",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:dir": "electron-builder --win --x64 --dir",
    "release": "electron-builder --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.yishou.chat-audit-export",
    "productName": "一手聊天审计导出",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "main.cjs",
      "main.mjs",
      "preload.cjs",
      "renderer/**/*",
      "src/**/*",
      "package.json",
      "!runtime/**",
      "!dist/**",
      "!scripts/**",
      "!build-log.txt"
    ],
    "asarUnpack": [
      "package.json",
      "main.mjs",
      "preload.cjs",
      "src/**",
      "renderer/**",
      "node_modules/ws/**"
    ],
    "extraResources": [
      {
        "from": "../chat-audit-export/scripts",
        "to": "scripts",
        "filter": ["**/*"]
      },
      {
        "from": "node_modules/ws",
        "to": "scripts/node_modules/ws",
        "filter": ["**/*"]
      },
      {
        "from": "runtime",
        "to": "runtime",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "executableName": "ChatAuditExport",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ChatAuditExport",
      "uninstallDisplayName": "ChatAuditExport"
    },
    "publish": {
      "provider": "github",
      "owner": "miantj",
      "repo": "chat-audit",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "ws": "^8.18.0"
  }
}