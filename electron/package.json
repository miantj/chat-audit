{
  "name": "chat-audit-export",
  "version": "1.0.0",
  "description": "一手聊天审计导出工具",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "prestart": "node scripts/ensure-deps.cjs",
    "start": "electron .",
    "rebuild:electron": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ pnpm rebuild electron",
    "prepare-runtime": "node scripts/prepare-runtime.cjs",
    "prebuild": "node scripts/prepare-runtime.cjs",
    "prebuild:mac": "node scripts/prepare-runtime.cjs",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.yishou.chat-audit-export",
    "productName": "一手聊天审计导出",
    "extraResources": [
      {
        "from": "../chat-audit-export/scripts",
        "to": "scripts",
        "filter": ["**/*"]
      },
      {
        "from": "runtime",
        "to": "runtime",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "pnpm": {
    "nodeLinker": "hoisted"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "ws": "^8.18.0"
  }
}