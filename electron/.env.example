# GitLab Personal Access Token（勿提交 .env）
# 创建：https://gitlab.yishou.com/-/user_settings/personal_access_tokens
# 权限建议：api、write_repository（私有项目必需）
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# 默认已配置为当前项目；如项目迁移再修改
GITLAB_BASE_URL=http://gitlab.yishou.com
